{
  "extensions": {
    "agent-chain": false,
    "agent-team": false,
    "cross-agent": false,
    "damage-control": false,
    "minimal": false,
    "pi-pi": false,
    "confirm-notify": false,
    "yu-notify": false,
    "pure-focus": false,
    "purpose-gate": false,
    "session-replay": false,
    "subagent-widget": false,
    "system-select": false,
    "theme-cycler": false,
    "tilldone": false,
    "tilldone-footer": true,
    "tool-counter": false,
